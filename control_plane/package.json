{
  "name": "swarmlord-control-plane",
  "version": "0.1.0",
  "description": "Terminal UI for SwarmLord AI Control Plane",

  "type": "module",
  "main": "dist/index.js",

  "scripts": {
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "build": "esbuild src/index.tsx --bundle --format=esm --platform=node --target=node18 --outfile=dist/index.js",
    "test": "jest"
  },

  "dependencies": {
    "ink": "^4.5.0",
    "react": "^18.2.0"
  },

  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "esbuild": "^0.20.0"
  },

  "keywords": ["terminal", "tui", "devops", "ai", "control-plane"],
  "author": "SwarmLord Team",
  "license": "MIT"
}

